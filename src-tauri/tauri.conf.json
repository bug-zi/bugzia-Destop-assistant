{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bugzia",
  "version": "0.1.0",
  "identifier": "com.bugzia.deskcard",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1520",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bugzia",
        "width": 420,
        "height": 64,
        "minWidth": 360,
        "minHeight": 64,
        "maxHeight": 64,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
